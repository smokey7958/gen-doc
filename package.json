{
  "name": "gen-doc",
  "version": "0.1.0",
  "description": "Gen Doc — 統一筆記 / 文書 / 表格 / 簡報，內建 AI 編輯助手",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "author": "Ven",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "ensure-electron": "node scripts/ensure-electron.cjs",
    "postinstall": "npm run ensure-electron && (electron-rebuild -f -w better-sqlite3 || echo 'rebuild skipped — run npm run rebuild manually after install')"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.1",
    "@formulajs/formulajs": "^4.6.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@univerjs/core": "^0.5.0",
    "@univerjs/design": "^0.5.0",
    "@univerjs/docs": "^0.5.0",
    "@univerjs/docs-ui": "^0.5.0",
    "@univerjs/engine-formula": "^0.5.0",
    "@univerjs/engine-render": "^0.5.0",
    "@univerjs/sheets": "^0.5.0",
    "@univerjs/sheets-formula": "^0.5.0",
    "@univerjs/sheets-ui": "^0.5.0",
    "@univerjs/ui": "^0.5.0",
    "better-sqlite3": "^11.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.1",
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.456.0",
    "mammoth": "^1.12.0",
    "marked": "^14.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "uuid": "^11.0.3",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.gendoc.app",
    "productName": "Gen Doc",
    "directories": {
      "output": "release"
    },
    "icon": "logo/logo.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "logo/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/*.node"
    ],
    "win": {
      "icon": "logo/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gen Doc",
      "installerIcon": "logo/logo.ico",
      "uninstallerIcon": "logo/logo.ico",
      "installerHeaderIcon": "logo/logo.ico"
    },
    "mac": {
      "icon": "logo/logo.png",
      "target": "dmg"
    },
    "linux": {
      "icon": "logo/logo.png",
      "target": "AppImage"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
